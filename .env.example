# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=your-secret-key-min-32-chars-change-this
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-this

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://portfolio_user:STRONG_PASSWORD@db:3306/portfolio_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REDIS_PASSWORD@redis:6379/2

# ── Mail ──────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@hibbo.tech
CONTACT_EMAIL=abubaker@hibbo.tech

# ── Site ──────────────────────────────────────────────────────
SITE_URL=https://hibbo.tech
# Comma-separated list of allowed origins for CORS.
# Include your domain + any admin panel domains.
# For local dev with Flutter admin, add: http://localhost:PORT
CORS_ORIGINS=https://hibbo.tech,https://www.hibbo.tech,https://admin.hibbo.tech

# ── Security ──────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY=your-32-byte-fernet-key-base64-encoded
CF_TURNSTILE_SECRET=your-cloudflare-turnstile-secret

# ── Storage ───────────────────────────────────────────────────
UPLOAD_FOLDER=/app/uploads

# ── MySQL (for docker-compose) ────────────────────────────────
MYSQL_ROOT_PASSWORD=ROOT_STRONG_PASSWORD
MYSQL_DATABASE=portfolio_db
MYSQL_USER=portfolio_user
MYSQL_PASSWORD=STRONG_PASSWORD

# ── Redis password ────────────────────────────────────────────
REDIS_PASSWORD=REDIS_STRONG_PASSWORD
